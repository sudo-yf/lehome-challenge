# 必填：工作区根目录（包含 pyproject.toml、.venv、Datasets/、outputs/）
LEHOME_WORKSPACE_ROOT=/root/data/lehome-challenge

# 必填：W&B token 文件。支持单行 token 或 KEY=VALUE env 文件。
WANDB_ENV_FILE=/root/data/wandb.md

# 可选：默认 W&B 工程名
WANDB_PROJECT=lehome_xvla_sweep_stage2
WANDB_MODE=online

# 推荐：把 W&B 数据与 artifact staging 放到数据盘
WANDB_DATA_DIR=/root/data/.cache/wandb-data
WANDB_ARTIFACT_DIR=/root/data/.cache/wandb-artifacts
TMPDIR=/root/data/.cache/tmp

# 可选：缓存热起来后建议开启离线模式
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# 可选：100 步 smoke 默认建议关闭模型 artifact 上传
WANDB_DISABLE_ARTIFACT=true
