set shell := ["bash", "-uc"]

bundle_dir := justfile_directory()

default:
    @just --list

preflight:
    bash "{{bundle_dir}}/bin/preflight.sh"

dryrun steps="100":
    STEPS="{{steps}}" bash "{{bundle_dir}}/bin/dryrun.sh"

smoke100-online:
    SMOKE_MODE=online bash "{{bundle_dir}}/bin/smoke100.sh"

smoke100-offline:
    SMOKE_MODE=offline bash "{{bundle_dir}}/bin/smoke100.sh"

smoke3x100-offline:
    SMOKE_MODE=offline bash "{{bundle_dir}}/bin/smoke3x100.sh"

create-only steps="3000" count="8":
    STEPS="{{steps}}" COUNT="{{count}}" bash "{{bundle_dir}}/bin/create_sweep.sh"

attach sweep_id count="4":
    SWEEP_ID="{{sweep_id}}" COUNT="{{count}}" bash "{{bundle_dir}}/bin/attach_sweep.sh"

strict-create steps="100":
    STEPS="{{steps}}" HF_HUB_OFFLINE=1 TRANSFORMERS_OFFLINE=1 WANDB_DISABLE_ARTIFACT=true bash "{{bundle_dir}}/bin/create_sweep.sh" --repro-mode strict --allow-dirty

strict-attach sweep_id count="1":
    SWEEP_ID="{{sweep_id}}" COUNT="{{count}}" HF_HUB_OFFLINE=1 TRANSFORMERS_OFFLINE=1 WANDB_DISABLE_ARTIFACT=true bash "{{bundle_dir}}/bin/attach_sweep.sh" --repro-mode strict --allow-dirty
